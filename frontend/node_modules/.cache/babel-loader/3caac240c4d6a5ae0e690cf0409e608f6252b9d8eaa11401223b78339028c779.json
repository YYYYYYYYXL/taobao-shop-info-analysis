{"ast":null,"code":"import CountTo from 'vue-count-to';\nimport Request from '../utils/request.js';\nexport default {\n  name: 'Home',\n  components: {\n    CountTo\n  },\n  data() {\n    return {\n      statistics: {\n        totalUsers: 0,\n        activeUsers: 0\n      }\n    };\n  },\n  created() {\n    this.getStatistics();\n  },\n  methods: {\n    async getStatistics() {\n      try {\n        const res = await Request.get('/actionLog/statistics');\n        if (res.code === '0' && res.data) {\n          this.statistics = {\n            totalUsers: Number(res.data.totalUsers) || 0,\n            activeUsers: Number(res.data.activeUsers) || 0\n          };\n        }\n      } catch (error) {\n        console.error('获取工作台统计数据失败:', error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["CountTo","Request","name","components","data","statistics","totalUsers","activeUsers","created","getStatistics","methods","res","get","code","Number","error","console"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard-wrapper\">\n    <div class=\"page-intro\">\n      <h2>工作台</h2>\n      <p>啧啧啧，我叫于鑫磊</p>\n    </div>\n\n    <div class=\"stat-cards\">\n      <el-card class=\"stat-card stat-card-blue\" shadow=\"hover\">\n        <div class=\"stat-header\">\n          <div class=\"stat-icon blue-icon\">\n            <i class=\"el-icon-user-solid\"></i>\n          </div>\n          <div class=\"stat-title\">用户总数</div>\n        </div>\n        <div class=\"stat-value\">\n          <count-to :startVal=\"0\" :endVal=\"statistics.totalUsers\" :duration=\"1200\" />\n        </div>\n        <div class=\"stat-footer\">当前系统内用户总量</div>\n      </el-card>\n\n      <el-card class=\"stat-card stat-card-green\" shadow=\"hover\">\n        <div class=\"stat-header\">\n          <div class=\"stat-icon green-icon\">\n            <i class=\"el-icon-success\"></i>\n          </div>\n          <div class=\"stat-title\">启用用户</div>\n        </div>\n        <div class=\"stat-value\">\n          <count-to :startVal=\"0\" :endVal=\"statistics.activeUsers\" :duration=\"1200\" />\n        </div>\n        <div class=\"stat-footer\">状态为启用的用户数量</div>\n      </el-card>\n    </div>\n  </div>\n</template>\n\n<script>\nimport CountTo from 'vue-count-to'\nimport Request from '../utils/request.js'\n\nexport default {\n  name: 'Home',\n  components: {\n    CountTo\n  },\n  data() {\n    return {\n      statistics: {\n        totalUsers: 0,\n        activeUsers: 0\n      }\n    }\n  },\n  created() {\n    this.getStatistics()\n  },\n  methods: {\n    async getStatistics() {\n      try {\n        const res = await Request.get('/actionLog/statistics')\n        if (res.code === '0' && res.data) {\n          this.statistics = {\n            totalUsers: Number(res.data.totalUsers) || 0,\n            activeUsers: Number(res.data.activeUsers) || 0\n          }\n        }\n      } catch (error) {\n        console.error('获取工作台统计数据失败:', error)\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"less\" scoped>\n.dashboard-wrapper {\n  padding: 24px;\n  background: #f9fafb;\n  min-height: calc(100vh - 60px);\n}\n\n.page-intro {\n  margin-bottom: 24px;\n\n  h2 {\n    margin: 0 0 8px;\n    font-size: 28px;\n    color: #111827;\n  }\n\n  p {\n    margin: 0;\n    color: #6b7280;\n    font-size: 14px;\n  }\n}\n\n.stat-cards {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(280px, 1fr));\n  gap: 24px;\n}\n\n.stat-card {\n  border: none;\n  border-radius: 16px;\n  transition: all 0.3s ease;\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);\n\n  &:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);\n  }\n\n  :deep(.el-card__body) {\n    padding: 24px;\n  }\n\n  &.stat-card-blue {\n    background: linear-gradient(135deg, rgba(59, 130, 246, 0.14) 0%, rgba(59, 130, 246, 0.08) 100%);\n  }\n\n  &.stat-card-green {\n    background: linear-gradient(135deg, rgba(16, 185, 129, 0.14) 0%, rgba(16, 185, 129, 0.08) 100%);\n  }\n\n  .stat-header {\n    display: flex;\n    align-items: center;\n    margin-bottom: 16px;\n  }\n\n  .stat-icon {\n    width: 48px;\n    height: 48px;\n    border-radius: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-right: 12px;\n    font-size: 24px;\n\n    &.blue-icon {\n      background: rgba(59, 130, 246, 0.15);\n      color: #2563eb;\n    }\n\n    &.green-icon {\n      background: rgba(16, 185, 129, 0.15);\n      color: #059669;\n    }\n  }\n\n  .stat-title {\n    font-size: 14px;\n    color: #6b7280;\n    font-weight: 500;\n  }\n\n  .stat-value {\n    font-size: 32px;\n    font-weight: 700;\n    margin-bottom: 8px;\n    color: #1f2937;\n  }\n\n  .stat-footer {\n    font-size: 13px;\n    color: #9ca3af;\n  }\n}\n\n@media screen and (max-width: 768px) {\n  .dashboard-wrapper {\n    padding: 16px;\n  }\n\n  .stat-cards {\n    grid-template-columns: 1fr;\n    gap: 16px;\n  }\n}\n</style>\n"],"mappings":"AAsCA,OAAAA,OAAA;AACA,OAAAC,OAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAH;EACA;EACAI,KAAA;IACA;MACAC,UAAA;QACAC,UAAA;QACAC,WAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,aAAA;EACA;EACAC,OAAA;IACA,MAAAD,cAAA;MACA;QACA,MAAAE,GAAA,SAAAV,OAAA,CAAAW,GAAA;QACA,IAAAD,GAAA,CAAAE,IAAA,YAAAF,GAAA,CAAAP,IAAA;UACA,KAAAC,UAAA;YACAC,UAAA,EAAAQ,MAAA,CAAAH,GAAA,CAAAP,IAAA,CAAAE,UAAA;YACAC,WAAA,EAAAO,MAAA,CAAAH,GAAA,CAAAP,IAAA,CAAAG,WAAA;UACA;QACA;MACA,SAAAQ,KAAA;QACAC,OAAA,CAAAD,KAAA,iBAAAA,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}