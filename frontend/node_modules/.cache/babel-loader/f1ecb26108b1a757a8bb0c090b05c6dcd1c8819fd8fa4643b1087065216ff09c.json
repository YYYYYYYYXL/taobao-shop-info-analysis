{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { setRoutes } from \"@/router\";\nimport Request from '../utils/request.js';\nimport { getIconByKey } from '../utils/iconMapping.js';\nconst __default__ = {\n  name: 'AsideMenu',\n  components: {},\n  // 用户信息\n  userInfo: {},\n  created() {\n    let userMenuListStr = localStorage.getItem(\"userMenuList\");\n    this.userMenuList = userMenuListStr ? JSON.parse(userMenuListStr) : [];\n    this.userInfo = localStorage.getItem(\"userInfo\") ? JSON.parse(localStorage.getItem(\"userInfo\")) : {};\n    // console.log(\"userMenuList:\" + userMenuListStr);\n  },\n  data() {\n    return {\n      userMenuList: [{\n        name: 'Dashboard',\n        path: 'dashboard',\n        icon: 'el-icon-menu'\n      }, {\n        name: 'Reports',\n        path: 'reports',\n        icon: 'el-icon-document',\n        children: [{\n          name: 'Report 1',\n          path: 'report1',\n          icon: 'el-icon-document'\n        }, {\n          name: 'Report 2',\n          path: 'report2',\n          icon: 'el-icon-document'\n        }]\n      }\n      // 更多静态菜单项...\n      ],\n      user: {},\n      path: this.$route.path\n    };\n  },\n  methods: {\n    // 判断是否是全屏页面（需要在新窗口打开）\n    isFullscreenPage(item) {\n      if (!item) return false;\n      return item.path === '/dashboard-fullscreen' || item.path === '/chat-fullscreen';\n    },\n    // 根据图标key获取对应的图标类\n    getIconClass(iconKey) {\n      if (!iconKey) return 'el-icon-menu';\n      return getIconByKey(iconKey);\n    },\n    printMenu(menu) {\n      // console.log(\"Submenu:\" + menu)\n    },\n    refreshMenu() {\n      Request.get(\"/menu/getMenuTree/\" + this.userInfo.id).then(response => {\n        if (response.code === '0') {\n          localStorage.setItem(\"userMenuList\", JSON.stringify(response.data));\n          setRoutes();\n        } else {\n          this.$message({\n            type: 'error',\n            message: response.msg\n          });\n        }\n      });\n    },\n    // 处理菜单选择事件（手动控制路由跳转）\n    handleMenuSelect(index, indexPath) {\n      // 如果 index 是纯数字字符串（可能是子菜单的 id），则忽略，因为子菜单本身不应该触发路由跳转\n      // 只有子菜单项（有 path 的菜单项）才会触发路由跳转\n      if (index && /^\\d+$/.test(index)) {\n        // 这是子菜单的 id，不应该触发路由跳转\n        return;\n      }\n\n      // 查找对应的菜单项\n      const menuItem = this.findMenuItemByPath(this.userMenuList, index);\n      if (menuItem && this.isFullscreenPage(menuItem)) {\n        // 全屏页面：新标签页打开，不进行路由跳转\n        const fullscreenUrl = menuItem.path;\n        window.open(fullscreenUrl, '_blank');\n\n        // 保持当前页面的菜单激活状态\n        this.$nextTick(() => {\n          // 强制更新菜单的激活状态为当前路由\n          if (this.$refs.menu) {\n            this.$refs.menu.activeIndex = this.$route.path;\n          }\n        });\n        return false;\n      }\n\n      // 其他菜单项：正常路由跳转（index 应该是路径字符串）\n      if (index && typeof index === 'string' && !/^\\d+$/.test(index) && this.$route.path !== index) {\n        this.$router.push(index).catch(err => {\n          // 忽略重复导航错误\n          if (err.name !== 'NavigationDuplicated') {\n            console.error(err);\n          }\n        });\n      }\n    },\n    // 根据路径查找菜单项\n    findMenuItemByPath(menuList, path) {\n      for (let item of menuList) {\n        if (item.path === path) {\n          return item;\n        }\n        if (item.children && item.children.length > 0) {\n          const found = this.findMenuItemByPath(item.children, path);\n          if (found) return found;\n        }\n      }\n      return null;\n    }\n  },\n  watch: {\n    // 监听路由变化，更新菜单激活状态\n    '$route'(to, from) {\n      this.$nextTick(() => {\n        if (this.$refs.menu) {\n          this.$refs.menu.activeIndex = to.path;\n        }\n      });\n    }\n  }\n};\nimport '../assets/iconfont.css';\nexport default /*#__PURE__*/Object.assign(__default__, {\n  setup(__props) {\n    return {\n      __sfc: true\n    };\n  }\n});","map":{"version":3,"names":["setRoutes","Request","getIconByKey","__default__","name","components","userInfo","created","userMenuListStr","localStorage","getItem","userMenuList","JSON","parse","data","path","icon","children","user","$route","methods","isFullscreenPage","item","getIconClass","iconKey","printMenu","menu","refreshMenu","get","id","then","response","code","setItem","stringify","$message","type","message","msg","handleMenuSelect","index","indexPath","test","menuItem","findMenuItemByPath","fullscreenUrl","window","open","$nextTick","$refs","activeIndex","$router","push","catch","err","console","error","menuList","length","found","watch","to","from"],"sources":["Aside.vue"],"sourcesContent":["<script setup>\nimport '../assets/iconfont.css';\n\n</script>\n<template>\n    <div>\n        <el-menu\n            ref=\"menu\"\n            :default-active=\"$route.path\"\n            class=\"el-menu-vertical\"\n            :collapse-transition=\"false\"\n            background-color=\"transparent\"\n            text-color=\"#606266\"\n            active-text-color=\"#fff\"\n            @select=\"handleMenuSelect\">\n\n            <div v-for=\"item in userMenuList\" :key=\"item.id\">\n                <div v-if=\"item.path\">\n                    <div v-if=\"!item.pid\">\n                        <el-menu-item \n                            :index=\"item.path\"\n                        >\n                            <i :class=\"getIconClass(item.icon)\"></i>\n                            <span>{{ item.name }}</span>\n                        </el-menu-item>\n                    </div>\n                </div>\n                <div v-else>\n                    <el-submenu :index=\"String(item.id)\">\n                        <template slot=\"title\">\n                            <i :class=\"getIconClass(item.icon)\"></i>\n                            <span>{{ item.name }}</span>\n                        </template>\n                        <div v-for=\"subItem in item.children\" :key=\"subItem.id\">\n                            <el-menu-item :index=\"subItem.path\">\n                                <i :class=\"getIconClass(subItem.icon)\"></i>\n                                <span>{{ subItem.name }}</span>\n                            </el-menu-item> \n                        </div>\n                    </el-submenu>\n                </div>\n            </div>\n        </el-menu>\n    </div>\n</template>\n\n<script>\n\n\nimport {setRoutes} from \"@/router\";\nimport Request from '../utils/request.js'\nimport { getIconByKey } from '../utils/iconMapping.js'\n\nexport default {\n    name: 'AsideMenu',\n    components: {},\n    // 用户信息\n    userInfo: {},\n    created() {\n        let userMenuListStr = localStorage.getItem(\"userMenuList\")\n        this.userMenuList = userMenuListStr ? JSON.parse(userMenuListStr) : [];\n        this.userInfo = localStorage.getItem(\"userInfo\") ? JSON.parse(localStorage.getItem(\"userInfo\")) : {};\n        // console.log(\"userMenuList:\" + userMenuListStr);\n    },\n    data() {\n        return {\n          \n            userMenuList: [\n                {\n                    name: 'Dashboard',\n                    path: 'dashboard',\n                    icon: 'el-icon-menu'\n                },\n                {\n                    name: 'Reports',\n                    path: 'reports',\n                    icon: 'el-icon-document',\n                    children: [\n                        {\n                            name: 'Report 1',\n                            path: 'report1',\n                            icon: 'el-icon-document'\n                        },\n                        {\n                            name: 'Report 2',\n                            path: 'report2',\n                            icon: 'el-icon-document'\n                        }\n                    ]\n                },\n                // 更多静态菜单项...\n            ],\n            user: {},\n            path: this.$route.path\n        }\n    },\n    methods: {\n        // 判断是否是全屏页面（需要在新窗口打开）\n        isFullscreenPage(item) {\n            if (!item) return false\n            return item.path === '/dashboard-fullscreen' || \n                   item.path === '/chat-fullscreen'\n        },\n        // 根据图标key获取对应的图标类\n        getIconClass(iconKey) {\n            if (!iconKey) return 'el-icon-menu'\n            return getIconByKey(iconKey)\n        },\n        printMenu(menu) {\n            // console.log(\"Submenu:\" + menu)\n        },\n        refreshMenu(){\n            Request.get(\"/menu/getMenuTree/\"+this.userInfo.id).then(response => {\n                if (response.code === '0') {\n                    localStorage.setItem(\"userMenuList\", JSON.stringify(response.data))\n                    setRoutes();\n         \n                } else {\n                    this.$message({\n                        type: 'error',\n                        message: response.msg\n                    })\n                }\n            })\n        },\n        \n        // 处理菜单选择事件（手动控制路由跳转）\n        handleMenuSelect(index, indexPath) {\n            // 如果 index 是纯数字字符串（可能是子菜单的 id），则忽略，因为子菜单本身不应该触发路由跳转\n            // 只有子菜单项（有 path 的菜单项）才会触发路由跳转\n            if (index && /^\\d+$/.test(index)) {\n                // 这是子菜单的 id，不应该触发路由跳转\n                return\n            }\n            \n            // 查找对应的菜单项\n            const menuItem = this.findMenuItemByPath(this.userMenuList, index)\n            \n            if (menuItem && this.isFullscreenPage(menuItem)) {\n                // 全屏页面：新标签页打开，不进行路由跳转\n                const fullscreenUrl = menuItem.path\n                window.open(fullscreenUrl, '_blank')\n                \n                // 保持当前页面的菜单激活状态\n                this.$nextTick(() => {\n                    // 强制更新菜单的激活状态为当前路由\n                    if (this.$refs.menu) {\n                        this.$refs.menu.activeIndex = this.$route.path\n                    }\n                })\n                return false\n            }\n            \n            // 其他菜单项：正常路由跳转（index 应该是路径字符串）\n            if (index && typeof index === 'string' && !/^\\d+$/.test(index) && this.$route.path !== index) {\n                this.$router.push(index).catch(err => {\n                    // 忽略重复导航错误\n                    if (err.name !== 'NavigationDuplicated') {\n                        console.error(err)\n                    }\n                })\n            }\n        },\n        \n        // 根据路径查找菜单项\n        findMenuItemByPath(menuList, path) {\n            for (let item of menuList) {\n                if (item.path === path) {\n                    return item\n                }\n                if (item.children && item.children.length > 0) {\n                    const found = this.findMenuItemByPath(item.children, path)\n                    if (found) return found\n                }\n            }\n            return null\n        }\n    },\n    watch: {\n        // 监听路由变化，更新菜单激活状态\n        '$route'(to, from) {\n            this.$nextTick(() => {\n                if (this.$refs.menu) {\n                    this.$refs.menu.activeIndex = to.path\n                }\n            })\n        }\n    }\n}\n</script>\n\n<style lang=\"less\" scoped>\n/* 侧边栏容器 */\n.el-menu-vertical {\n    border-right: none;\n    padding: 16px 12px;\n    background: linear-gradient(90deg, #4a90e2 0%, #e8f4fd 100%);\n    min-height: 100vh;\n}\n\n/* 菜单项基础样式 */\n.el-menu-item {\n    height: 48px;\n    line-height: 48px;\n    border-radius: 8px;\n    margin-bottom: 4px;\n    color: #4a5568;\n    font-size: 14px;\n    font-weight: 400;\n    padding: 0 16px !important;\n    transition: all 0.3s ease;\n    background-color: transparent;\n    \n    &:hover {\n        color: #4a5568;\n        background-color: rgba(255, 255, 255, 0.3) !important;\n    }\n    \n    &.is-active {\n        color: #fff;\n        background: #4a90e2 !important;\n        font-weight: 600;\n        box-shadow: 0 2px 8px rgba(74, 144, 226, 0.3);\n        position: relative;\n        \n        &::before {\n            content: '';\n            position: absolute;\n            left: 0;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 4px;\n            height: 24px;\n            background: #fff;\n            border-radius: 0 2px 2px 0;\n        }\n    }\n}\n\n/* 子菜单标题样式 */\n.el-submenu ::v-deep .el-submenu__title {\n    height: 48px;\n    line-height: 48px;\n    border-radius: 8px;\n    color: #4a5568;\n    font-size: 14px;\n    font-weight: 400;\n    padding: 0 16px !important;\n    margin-bottom: 4px;\n    transition: all 0.3s ease;\n    background-color: transparent;\n    \n    &:hover {\n        color: #4a5568;\n        background-color: rgba(255, 255, 255, 0.3) !important;\n    }\n}\n\n/* 展开的子菜单标题样式 */\n.el-submenu.is-opened ::v-deep .el-submenu__title {\n    color: #fff;\n    background-color: rgba(255, 255, 255, 0.2) !important;\n}\n\n/* 子菜单项容器 */\n.el-submenu ::v-deep .el-menu--inline {\n    padding-left: 0;\n    background-color: transparent;\n    margin-top: 4px;\n    margin-bottom: 8px;\n    \n    .el-menu-item {\n        height: 44px;\n        line-height: 44px;\n        padding-left: 48px !important;\n        background-color: transparent;\n        margin-bottom: 2px;\n        color: #4a5568;\n        border-radius: 6px;\n        \n        &:hover {\n            color: #4a5568;\n            background-color: rgba(255, 255, 255, 0.2) !important;\n        }\n        \n        &.is-active {\n            color: #fff;\n            background: #4a90e2 !important;\n            font-weight: 600;\n            width: 100%;\n            box-shadow: 0 2px 6px rgba(74, 144, 226, 0.25);\n            position: relative;\n            \n            &::before {\n                content: '';\n                position: absolute;\n                left: 0;\n                top: 50%;\n                transform: translateY(-50%);\n                width: 3px;\n                height: 20px;\n                background: #fff;\n                border-radius: 0 2px 2px 0;\n            }\n        }\n    }\n}\n\n/* 图标样式 */\n.el-menu-item [class^=\"el-icon-\"],\n.el-submenu [class^=\"el-icon-\"] {\n    font-size: 18px;\n    margin-right: 12px;\n    color: #718096;\n    transition: color 0.3s ease;\n}\n\n.el-menu-item:hover [class^=\"el-icon-\"],\n.el-submenu:hover [class^=\"el-icon-\"] {\n    color: #4a5568;\n}\n\n.el-menu-item.is-active [class^=\"el-icon-\"] {\n    color: #fff;\n}\n\n.el-submenu.is-opened [class^=\"el-icon-\"],\n.el-submenu.is-opened ::v-deep .el-submenu__title [class^=\"el-icon-\"] {\n    color: #fff;\n}\n\n/* 箭头图标样式 */\n.el-submenu ::v-deep .el-submenu__icon-arrow {\n    color: #718096;\n    font-size: 12px;\n    margin-top: -6px;\n    transition: all 0.3s ease;\n    right: 16px;\n}\n\n.el-submenu:hover ::v-deep .el-submenu__icon-arrow {\n    color: #4a5568;\n}\n\n.el-submenu.is-opened ::v-deep .el-submenu__icon-arrow {\n    color: #fff;\n    transform: rotate(180deg);\n}\n</style>"],"mappings":";AAiDA,SAAQA,SAAS,QAAO,UAAU;AAClC,OAAOC,OAAO,MAAM,qBAAqB;AACzC,SAASC,YAAY,QAAQ,yBAAyB;AAEtD,MAAAC,WAAA,GAAe;EACXC,IAAI,EAAE,WAAW;EACjBC,UAAU,EAAE,CAAC,CAAC;EACd;EACAC,QAAQ,EAAE,CAAC,CAAC;EACZC,OAAOA,CAAA,EAAG;IACN,IAAIC,eAAe,GAAGC,YAAY,CAACC,OAAO,CAAC,cAAc,CAAC;IAC1D,IAAI,CAACC,YAAY,GAAGH,eAAe,GAAGI,IAAI,CAACC,KAAK,CAACL,eAAe,CAAC,GAAG,EAAE;IACtE,IAAI,CAACF,QAAQ,GAAGG,YAAY,CAACC,OAAO,CAAC,UAAU,CAAC,GAAGE,IAAI,CAACC,KAAK,CAACJ,YAAY,CAACC,OAAO,CAAC,UAAU,CAAC,CAAC,GAAG,CAAC,CAAC;IACpG;EACJ,CAAC;EACDI,IAAIA,CAAA,EAAG;IACH,OAAO;MAEHH,YAAY,EAAE,CACV;QACIP,IAAI,EAAE,WAAW;QACjBW,IAAI,EAAE,WAAW;QACjBC,IAAI,EAAE;MACV,CAAC,EACD;QACIZ,IAAI,EAAE,SAAS;QACfW,IAAI,EAAE,SAAS;QACfC,IAAI,EAAE,kBAAkB;QACxBC,QAAQ,EAAE,CACN;UACIb,IAAI,EAAE,UAAU;UAChBW,IAAI,EAAE,SAAS;UACfC,IAAI,EAAE;QACV,CAAC,EACD;UACIZ,IAAI,EAAE,UAAU;UAChBW,IAAI,EAAE,SAAS;UACfC,IAAI,EAAE;QACV,CAAC;MAET;MACA;MAAA,CACH;MACDE,IAAI,EAAE,CAAC,CAAC;MACRH,IAAI,EAAE,IAAI,CAACI,MAAM,CAACJ;IACtB,CAAC;EACL,CAAC;EACDK,OAAO,EAAE;IACL;IACAC,gBAAgBA,CAACC,IAAI,EAA