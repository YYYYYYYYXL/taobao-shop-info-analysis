{"ast":null,"code":"import * as echarts from 'echarts';\nimport { getAnalysisSummary } from '@/api/analysis';\nexport default {\n  name: 'AnalysisCategorySales',\n  data() {\n    return {\n      loading: true,\n      errorMsg: '',\n      chartInstance: null,\n      chartData: []\n    };\n  },\n  async mounted() {\n    try {\n      const res = await getAnalysisSummary();\n      this.chartData = Array.isArray(res.data?.data) ? res.data.data : [];\n      this.$nextTick(() => {\n        this.initChart();\n      });\n    } catch (error) {\n      if (error.response) {\n        this.errorMsg = `请求失败，状态码：${error.response.status}`;\n      } else if (error.request) {\n        this.errorMsg = '请求已发出，但后端没有正常响应';\n      } else {\n        this.errorMsg = `请求错误：${error.message}`;\n      }\n      console.error(error);\n    } finally {\n      this.loading = false;\n    }\n  },\n  methods: {\n    initChart() {\n      if (!this.$refs.chartRef) return;\n      if (!this.chartData.length) return;\n      this.chartInstance = echarts.init(this.$refs.chartRef);\n      this.chartInstance.setOption({\n        tooltip: {\n          trigger: 'item'\n        },\n        legend: {\n          orient: 'vertical',\n          left: 'left'\n        },\n        series: [{\n          name: '分类销量',\n          type: 'pie',\n          radius: ['45%', '70%'],\n          data: this.chartData\n        }]\n      });\n    }\n  },\n  beforeDestroy() {\n    if (this.chartInstance) {\n      this.chartInstance.dispose();\n      this.chartInstance = null;\n    }\n  }\n};","map":{"version":3,"names":["echarts","getAnalysisSummary","name","data","loading","errorMsg","chartInstance","chartData","mounted","res","Array","isArray","$nextTick","initChart","error","response","status","request","message","console","methods","$refs","chartRef","length","init","setOption","tooltip","trigger","legend","orient","left","series","type","radius","beforeDestroy","dispose"],"sources":["src/views/analysis/AnalysisCategorySales.vue"],"sourcesContent":["<template>\r\n    <div style=\"padding: 20px;\">\r\n      <h2>分类销量分析</h2>\r\n\r\n      <p v-if=\"loading\">数据加载中...</p>\r\n      <p v-else-if=\"errorMsg\" style=\"color: red;\">{{ errorMsg }}</p>\r\n\r\n      <div v-else>\r\n        <div style=\"margin-bottom: 20px;\">\r\n          <div>数据条数：{{ chartData.length }}</div>\r\n          <pre style=\"background:#f5f5f5;padding:12px;white-space:pre-wrap;\">{{ chartData }}</pre>\r\n        </div>\r\n\r\n        <div ref=\"chartRef\" style=\"width: 100%; height: 600px;\"></div>\r\n      </div>\r\n    </div>\r\n  </template>\r\n\r\n  <script>\r\n  import * as echarts from 'echarts'\r\n  import { getAnalysisSummary } from '@/api/analysis'\r\n\r\n  export default {\r\n    name: 'AnalysisCategorySales',\r\n    data() {\r\n      return {\r\n        loading: true,\r\n        errorMsg: '',\r\n        chartInstance: null,\r\n        chartData: []\r\n      }\r\n    },\r\n    async mounted() {\r\n      try {\r\n        const res = await getAnalysisSummary()\r\n        this.chartData = Array.isArray(res.data?.data) ? res.data.data : []\r\n        this.$nextTick(() => {\r\n          this.initChart()\r\n        })\r\n      } catch (error) {\r\n        if (error.response) {\r\n          this.errorMsg = `请求失败，状态码：${error.response.status}`\r\n        } else if (error.request) {\r\n          this.errorMsg = '请求已发出，但后端没有正常响应'\r\n        } else {\r\n          this.errorMsg = `请求错误：${error.message}`\r\n        }\r\n        console.error(error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    methods: {\r\n      initChart() {\r\n        if (!this.$refs.chartRef) return\r\n        if (!this.chartData.length) return\r\n\r\n        this.chartInstance = echarts.init(this.$refs.chartRef)\r\n        this.chartInstance.setOption({\r\n          tooltip: { trigger: 'item' },\r\n          legend: { orient: 'vertical', left: 'left' },\r\n          series: [\r\n            {\r\n              name: '分类销量',\r\n              type: 'pie',\r\n              radius: ['45%', '70%'],\r\n              data: this.chartData\r\n            }\r\n          ]\r\n        })\r\n      }\r\n    },\r\n    beforeDestroy() {\r\n      if (this.chartInstance) {\r\n        this.chartInstance.dispose()\r\n        this.chartInstance = null\r\n      }\r\n    }\r\n  }\r\n  </script>"],"mappings":"AAmBA,YAAAA,OAAA;AACA,SAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,QAAA;MACAC,aAAA;MACAC,SAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA;MACA,MAAAC,GAAA,SAAAR,kBAAA;MACA,KAAAM,SAAA,GAAAG,KAAA,CAAAC,OAAA,CAAAF,GAAA,CAAAN,IAAA,EAAAA,IAAA,IAAAM,GAAA,CAAAN,IAAA,CAAAA,IAAA;MACA,KAAAS,SAAA;QACA,KAAAC,SAAA;MACA;IACA,SAAAC,KAAA;MACA,IAAAA,KAAA,CAAAC,QAAA;QACA,KAAAV,QAAA,eAAAS,KAAA,CAAAC,QAAA,CAAAC,MAAA;MACA,WAAAF,KAAA,CAAAG,OAAA;QACA,KAAAZ,QAAA;MACA;QACA,KAAAA,QAAA,WAAAS,KAAA,CAAAI,OAAA;MACA;MACAC,OAAA,CAAAL,KAAA,CAAAA,KAAA;IACA;MACA,KAAAV,OAAA;IACA;EACA;EACAgB,OAAA;IACAP,UAAA;MACA,UAAAQ,KAAA,CAAAC,QAAA;MACA,UAAAf,SAAA,CAAAgB,MAAA;MAEA,KAAAjB,aAAA,GAAAN,OAAA,CAAAwB,IAAA,MAAAH,KAAA,CAAAC,QAAA;MACA,KAAAhB,aAAA,CAAAmB,SAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAC,MAAA;UAAAC,MAAA;UAAAC,IAAA;QAAA;QACAC,MAAA,GACA;UACA7B,IAAA;UACA8B,IAAA;UACAC,MAAA;UACA9B,IAAA,OAAAI;QACA;MAEA;IACA;EACA;EACA2B,cAAA;IACA,SAAA5B,aAAA;MACA,KAAAA,aAAA,CAAA6B,OAAA;MACA,KAAA7B,aAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}