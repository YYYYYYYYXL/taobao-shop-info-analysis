{"ast":null,"code":"import \"core-js/modules/esnext.iterator.map.js\";\nimport * as echarts from 'echarts';\nimport { getAnalysisSummary } from '@/api/analysis';\nexport default {\n  name: 'AnalysisCategorySales',\n  data() {\n    return {\n      loading: true,\n      errorMsg: '',\n      chartInstance: null,\n      chartData: []\n    };\n  },\n  async mounted() {\n    try {\n      const res = await getAnalysisSummary();\n      const categorySales = res.data?.data || [];\n      this.chartData = categorySales.map(item => ({\n        name: item.name,\n        value: item.value\n      }));\n      this.$nextTick(() => {\n        this.initChart();\n      });\n    } catch (error) {\n      if (error.response) {\n        this.errorMsg = `请求失败，状态码：${error.response.status}`;\n      } else if (error.request) {\n        this.errorMsg = '请求已发出，但后端没有正常响应';\n      } else {\n        this.errorMsg = `请求错误：${error.message}`;\n      }\n      console.error(error);\n    } finally {\n      this.loading = false;\n    }\n  },\n  methods: {\n    initChart() {\n      if (!this.$refs.chartRef) return;\n      if (!this.chartData.length) return;\n      this.chartInstance = echarts.init(this.$refs.chartRef);\n      const option = {\n        tooltip: {\n          trigger: 'item'\n        },\n        legend: {\n          orient: 'vertical',\n          left: 'left'\n        },\n        series: [{\n          name: '分类销量',\n          type: 'pie',\n          radius: ['45%', '70%'],\n          avoidLabelOverlap: false,\n          itemStyle: {\n            borderRadius: 8,\n            borderColor: '#fff',\n            borderWidth: 2\n          },\n          label: {\n            show: true,\n            formatter: '{b}: {c} ({d}%)'\n          },\n          emphasis: {\n            label: {\n              show: true,\n              fontSize: 16,\n              fontWeight: 'bold'\n            }\n          },\n          labelLine: {\n            show: true\n          },\n          data: this.chartData\n        }]\n      };\n      this.chartInstance.setOption(option);\n    }\n  },\n  beforeDestroy() {\n    if (this.chartInstance) {\n      this.chartInstance.dispose();\n      this.chartInstance = null;\n    }\n  }\n};","map":{"version":3,"names":["echarts","getAnalysisSummary","name","data","loading","errorMsg","chartInstance","chartData","mounted","res","categorySales","map","item","value","$nextTick","initChart","error","response","status","request","message","console","methods","$refs","chartRef","length","init","option","tooltip","trigger","legend","orient","left","series","type","radius","avoidLabelOverlap","itemStyle","borderRadius","borderColor","borderWidth","label","show","formatter","emphasis","fontSize","fontWeight","labelLine","setOption","beforeDestroy","dispose"],"sources":["src/views/analysis/AnalysisCategorySales.vue"],"sourcesContent":[" <template>\r\n    <div style=\"padding: 20px;\">\r\n      <h2>分类销量分析</h2>\r\n\r\n      <p v-if=\"loading\">数据加载中...</p>\r\n      <p v-else-if=\"errorMsg\" style=\"color: red;\">{{ errorMsg }}</p>\r\n\r\n      <div v-else>\r\n        <div ref=\"chartRef\" style=\"width: 100%; height: 600px;\"></div>\r\n      </div>\r\n    </div>\r\n  </template>\r\n\r\n  <script>\r\n  import * as echarts from 'echarts'\r\n  import { getAnalysisSummary } from '@/api/analysis'\r\n\r\n  export default {\r\n    name: 'AnalysisCategorySales',\r\n    data() {\r\n      return {\r\n        loading: true,\r\n        errorMsg: '',\r\n        chartInstance: null,\r\n        chartData: []\r\n      }\r\n    },\r\n    async mounted() {\r\n      try {\r\n        const res = await getAnalysisSummary()\r\n        const categorySales = res.data?.data || []\r\n\r\n        this.chartData = categorySales.map(item => ({\r\n          name: item.name,\r\n          value: item.value\r\n        }))\r\n\r\n        this.$nextTick(() => {\r\n          this.initChart()\r\n        })\r\n      } catch (error) {\r\n        if (error.response) {\r\n          this.errorMsg = `请求失败，状态码：${error.response.status}`\r\n        } else if (error.request) {\r\n          this.errorMsg = '请求已发出，但后端没有正常响应'\r\n        } else {\r\n          this.errorMsg = `请求错误：${error.message}`\r\n        }\r\n        console.error(error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    methods: {\r\n      initChart() {\r\n        if (!this.$refs.chartRef) return\r\n        if (!this.chartData.length) return\r\n\r\n        this.chartInstance = echarts.init(this.$refs.chartRef)\r\n\r\n        const option = {\r\n          tooltip: {\r\n            trigger: 'item'\r\n          },\r\n          legend: {\r\n            orient: 'vertical',\r\n            left: 'left'\r\n          },\r\n          series: [\r\n            {\r\n              name: '分类销量',\r\n              type: 'pie',\r\n              radius: ['45%', '70%'],\r\n              avoidLabelOverlap: false,\r\n              itemStyle: {\r\n                borderRadius: 8,\r\n                borderColor: '#fff',\r\n                borderWidth: 2\r\n              },\r\n              label: {\r\n                show: true,\r\n                formatter: '{b}: {c} ({d}%)'\r\n              },\r\n              emphasis: {\r\n                label: {\r\n                  show: true,\r\n                  fontSize: 16,\r\n                  fontWeight: 'bold'\r\n                }\r\n              },\r\n              labelLine: {\r\n                show: true\r\n              },\r\n              data: this.chartData\r\n            }\r\n          ]\r\n        }\r\n\r\n        this.chartInstance.setOption(option)\r\n      }\r\n    },\r\n    beforeDestroy() {\r\n      if (this.chartInstance) {\r\n        this.chartInstance.dispose()\r\n        this.chartInstance = null\r\n      }\r\n    }\r\n  }\r\n  </script>"],"mappings":";AAcA,YAAAA,OAAA;AACA,SAAAC,kBAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,QAAA;MACAC,aAAA;MACAC,SAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA;MACA,MAAAC,GAAA,SAAAR,kBAAA;