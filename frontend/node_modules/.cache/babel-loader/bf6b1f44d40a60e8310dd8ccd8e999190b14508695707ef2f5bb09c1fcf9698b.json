{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'LRLayout',\n  data() {\n    return {\n      title: process.env.VUE_APP_TITLE || '数据分析系统'\n    };\n  },\n  mounted() {\n    // 禁用页面滚动\n    document.body.style.overflow = 'hidden';\n  },\n  beforeDestroy() {\n    // 恢复页面滚动\n    document.body.style.overflow = '';\n  },\n  methods: {\n    goToHome() {\n      this.$router.push('/');\n    }\n  }\n};","map":{"version":3,"names":["name","data","title","process","env","VUE_APP_TITLE","mounted","document","body","style","overflow","beforeDestroy","methods","goToHome","$router","push"],"sources":["src/layout/LRLayout.vue"],"sourcesContent":["<template>\n    <div class=\"lr-container\">\n<!--        <el-button class=\"back-home-btn\" type=\"success\" @click=\"goToHome\">-->\n<!--            <i class=\"el-icon-back\"></i>-->\n<!--            返回首页-->\n<!--        </el-button>-->\n        <div class=\"lr-content\">\n            <div class=\"lr-right\">\n                <router-view />\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'LRLayout',\n    data() {\n        return {\n            title: process.env.VUE_APP_TITLE || '数据分析系统'\n        }\n    },\n    mounted() {\n        // 禁用页面滚动\n        document.body.style.overflow = 'hidden'\n    },\n    beforeDestroy() {\n        // 恢复页面滚动\n        document.body.style.overflow = ''\n    },\n    methods: {\n        goToHome() {\n            this.$router.push('/')\n        }\n    }\n}\n</script>\n\n<style scoped>\n.lr-container {\n    height: 100vh;\n    overflow: hidden;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: linear-gradient(90deg, #4a90e2 0%, #e8f4fd 100%);\n    position: relative;\n}\n\n.lr-content {\n    display: flex;\n    width: 100%;\n    max-width: 420px;\n    max-height: 100vh;\n    background: rgba(255, 255, 255, 0.98);\n    backdrop-filter: blur(20px);\n    border-radius: 16px;\n    box-shadow: \n        0 20px 60px rgba(74, 144, 226, 0.15),\n        0 0 0 1px rgba(255, 255, 255, 0.5);\n    overflow-y: auto;\n    overflow-x: hidden;\n    animation: slideUp 0.6s ease-out;\n    position: relative;\n    z-index: 1;\n    \n    /* 隐藏滚动条 */\n    scrollbar-width: none; /* Firefox */\n    -ms-overflow-style: none; /* IE 和 Edge */\n    \n    &::-webkit-scrollbar {\n      display: none; /* Chrome, Safari, Opera */\n    }\n}\n\n.lr-left {\n    flex: 1;\n    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 60px;\n    position: relative;\n    overflow: hidden;\n}\n\n.brand-info {\n    position: relative;\n    color: white;\n    text-align: center;\n    z-index: 1;\n}\n\n.logo-container {\n    width: 80px;\n    height: 80px;\n    margin: 0 auto 24px;\n    background: rgba(255, 255, 255, 0.2);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.logo-container i {\n    font-size: 40px;\n}\n\n.brand-info h1 {\n    font-size: 36px;\n    font-weight: 600;\n    margin-bottom: 16px;\n    letter-spacing: 1px;\n}\n\n.brand-info p {\n    font-size: 18px;\n    opacity: 0.9;\n    margin-bottom: 40px;\n}\n\n.features {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 20px;\n    margin-top: 60px;\n}\n\n.feature-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 12px;\n}\n\n.feature-item i {\n    font-size: 32px;\n    opacity: 0.9;\n}\n\n.feature-item span {\n    font-size: 14px;\n}\n\n.lr-right {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 40px 36px;\n    background: transparent;\n}\n\n@keyframes slideUp {\n    from {\n        opacity: 0;\n        transform: translateY(30px) scale(0.95);\n    }\n    to {\n        opacity: 1;\n        transform: translateY(0) scale(1);\n    }\n}\n\n@media (max-width: 1200px) {\n    .lr-content {\n        max-width: 400px;\n    }\n}\n\n@media (max-width: 768px) {\n    .lr-container {\n        padding: 16px;\n    }\n    \n    .lr-content {\n        max-width: 100%;\n        border-radius: 16px;\n    }\n    \n    .lr-right {\n        padding: 32px 28px;\n    }\n    \n    .lr-left {\n        display: none;\n    }\n}\n\n.back-home-btn {\n    position: fixed;\n    top: 20px;\n    left: 20px;\n    font-size: 14px;\n    padding: 8px 12px;\n    border-radius: 8px;\n    transition: all 0.3s ease;\n    z-index: 100;\n}\n\n.back-home-btn:hover {\n    transform: translateX(-4px);\n    box-shadow: 0 2px 8px rgba(103, 194, 58, 0.2);\n}\n\n.back-home-btn i {\n    margin-right: 4px;\n    transition: transform 0.3s ease;\n}\n\n.back-home-btn:hover i {\n    transform: translateX(-2px);\n}\n</style>"],"mappings":";AAeA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,KAAA,EAAAC,OAAA,CAAAC,GAAA,CAAAC,aAAA;IACA;EACA;EACAC,QAAA;IACA;IACAC,QAAA,CAAAC,IAAA,CAAAC,KAAA,CAAAC,QAAA;EACA;EACAC,cAAA;IACA;IACAJ,QAAA,CAAAC,IAAA,CAAAC,KAAA,CAAAC,QAAA;EACA;EACAE,OAAA;IACAC,SAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}