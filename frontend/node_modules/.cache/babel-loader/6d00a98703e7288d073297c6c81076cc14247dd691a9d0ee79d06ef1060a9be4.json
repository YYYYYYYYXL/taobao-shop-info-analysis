{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'BaseChart',\n  props: {\n    title: {\n      type: String,\n      default: ''\n    },\n    height: {\n      type: Number,\n      default: 300\n    },\n    options: {\n      type: Object,\n      required: true\n    },\n    theme: {\n      type: String,\n      default: 'default'\n    }\n  },\n  data() {\n    return {\n      chart: null\n    };\n  },\n  mounted() {\n    this.initChart();\n    window.addEventListener('resize', this.handleResize);\n  },\n  beforeDestroy() {\n    if (this.chart) {\n      this.chart.dispose();\n    }\n    window.removeEventListener('resize', this.handleResize);\n  },\n  watch: {\n    options: {\n      handler(newOptions) {\n        if (this.chart) {\n          this.chart.setOption(newOptions, true);\n        }\n      },\n      deep: true\n    }\n  },\n  methods: {\n    initChart() {\n      this.chart = echarts.init(this.$refs.chartRef, this.theme);\n      this.chart.setOption(this.options);\n    },\n    handleResize() {\n      if (this.chart) {\n        this.chart.resize();\n      }\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","props","title","type","String","default","height","Number","options","Object","required","theme","data","chart","mounted","initChart","window","addEventListener","handleResize","beforeDestroy","dispose","removeEventListener","watch","handler","newOptions","setOption","deep","methods","init","$refs","chartRef","resize"],"sources":["src/components/Chart/BaseChart.vue"],"sourcesContent":["<template>\n    <div ref=\"chartRef\" class=\"chart-content\" :style=\"{ height: height + 'px' }\"></div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n\nexport default {\n  name: 'BaseChart',\n  props: {\n    title: {\n      type: String,\n      default: ''\n    },\n    height: {\n      type: Number,\n      default: 300\n    },\n    options: {\n      type: Object,\n      required: true\n    },\n    theme: {\n      type: String,\n      default: 'default'\n    }\n  },\n  data() {\n    return {\n      chart: null\n    }\n  },\n  mounted() {\n    this.initChart()\n    window.addEventListener('resize', this.handleResize)\n  },\n  beforeDestroy() {\n    if (this.chart) {\n      this.chart.dispose()\n    }\n    window.removeEventListener('resize', this.handleResize)\n  },\n  watch: {\n    options: {\n      handler(newOptions) {\n        if (this.chart) {\n          this.chart.setOption(newOptions, true)\n        }\n      },\n      deep: true\n    }\n  },\n  methods: {\n    initChart() {\n      this.chart = echarts.init(this.$refs.chartRef, this.theme)\n      this.chart.setOption(this.options)\n    },\n    handleResize() {\n      if (this.chart) {\n        this.chart.resize()\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.chart-content {\n  width: 100%;\n}\n</style>\n"],"mappings":"AAKA,YAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACAC,KAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAC,MAAA;MACAH,IAAA,EAAAI,MAAA;MACAF,OAAA;IACA;IACAG,OAAA;MACAL,IAAA,EAAAM,MAAA;MACAC,QAAA;IACA;IACAC,KAAA;MACAR,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;EACA;EACAO,KAAA;IACA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;IACAC,MAAA,CAAAC,gBAAA,gBAAAC,YAAA;EACA;EACAC,cAAA;IACA,SAAAN,KAAA;MACA,KAAAA,KAAA,CAAAO,OAAA;IACA;IACAJ,MAAA,CAAAK,mBAAA,gBAAAH,YAAA;EACA;EACAI,KAAA;IACAd,OAAA;MACAe,QAAAC,UAAA;QACA,SAAAX,KAAA;UACA,KAAAA,KAAA,CAAAY,SAAA,CAAAD,UAAA;QACA;MACA;MACAE,IAAA;IACA;EACA;EACAC,OAAA;IACAZ,UAAA;MACA,KAAAF,KAAA,GAAAd,OAAA,CAAA6B,IAAA,MAAAC,KAAA,CAAAC,QAAA,OAAAnB,KAAA;MACA,KAAAE,KAAA,CAAAY,SAAA,MAAAjB,OAAA;IACA;IACAU,aAAA;MACA,SAAAL,KAAA;QACA,KAAAA,KAAA,CAAAkB,MAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}