{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'TestApi',\n  data() {\n    return {\n      loading: true,\n      errorMsg: '',\n      categorySales: []\n    };\n  },\n  async mounted() {\n    console.log('页面 mounted 开始执行');\n    try {\n      const res = await axios.get('http://127.0.0.1:8000/api/summary/');\n      console.log('后端返回数据：', res.data);\n      this.categorySales = res.data.data.category_sales;\n      console.log('categorySales：', this.categorySales);\n    } catch (error) {\n      console.error('请求失败详情：', error);\n      if (error.response) {\n        this.errorMsg = `请求失败，状态码：${error.response.status}`;\n      } else if (error.request) {\n        this.errorMsg = '请求已发出，但后端没有正常响应';\n      } else {\n        this.errorMsg = `请求错误：${error.message}`;\n      }\n    } finally {\n      this.loading = false;\n      console.log('mounted 执行结束');\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","loading","errorMsg","categorySales","mounted","console","log","res","get","category_sales","error","response","status","request","message"],"sources":["src/views/TestApi.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <h1 style=\"color: red;\">我进入 TestApi 页面了</h1>\r\n\r\n    <p>loading: {{ loading }}</p>\r\n    <p>errorMsg: {{ errorMsg }}</p>\r\n    <p>categorySales长度: {{ categorySales.length }}</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\n\r\nexport default {\r\n  name: 'TestApi',\r\n  data() {\r\n    return {\r\n      loading: true,\r\n      errorMsg: '',\r\n      categorySales: []\r\n    }\r\n  },\r\n  async mounted() {\r\n    console.log('页面 mounted 开始执行')\r\n\r\n    try {\r\n      const res = await axios.get('http://127.0.0.1:8000/api/summary/')\r\n      console.log('后端返回数据：', res.data)\r\n\r\n      this.categorySales = res.data.data.category_sales\r\n      console.log('categorySales：', this.categorySales)\r\n    } catch (error) {\r\n      console.error('请求失败详情：', error)\r\n\r\n      if (error.response) {\r\n        this.errorMsg = `请求失败，状态码：${error.response.status}`\r\n      } else if (error.request) {\r\n        this.errorMsg = '请求已发出，但后端没有正常响应'\r\n      } else {\r\n        this.errorMsg = `请求错误：${error.message}`\r\n      }\r\n    } finally {\r\n      this.loading = false\r\n      console.log('mounted 执行结束')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AAWA,OAAAA,KAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,QAAA;MACAC,aAAA;IACA;EACA;EACA,MAAAC,QAAA;IACAC,OAAA,CAAAC,GAAA;IAEA;MACA,MAAAC,GAAA,SAAAT,KAAA,CAAAU,GAAA;MACAH,OAAA,CAAAC,GAAA,YAAAC,GAAA,CAAAP,IAAA;MAEA,KAAAG,aAAA,GAAAI,GAAA,CAAAP,IAAA,CAAAA,IAAA,CAAAS,cAAA;MACAJ,OAAA,CAAAC,GAAA,wBAAAH,aAAA;IACA,SAAAO,KAAA;MACAL,OAAA,CAAAK,KAAA,YAAAA,KAAA;MAEA,IAAAA,KAAA,CAAAC,QAAA;QACA,KAAAT,QAAA,eAAAQ,KAAA,CAAAC,QAAA,CAAAC,MAAA;MACA,WAAAF,KAAA,CAAAG,OAAA;QACA,KAAAX,QAAA;MACA;QACA,KAAAA,QAAA,WAAAQ,KAAA,CAAAI,OAAA;MACA;IACA;MACA,KAAAb,OAAA;MACAI,OAAA,CAAAC,GAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}