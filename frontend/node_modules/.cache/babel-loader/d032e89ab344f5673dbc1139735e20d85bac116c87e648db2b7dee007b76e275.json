{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'TestApi',\n  data() {\n    return {\n      loading: true,\n      errorMsg: '',\n      categorySales: []\n    };\n  },\n  async mounted() {\n    try {\n      const res = await axios.get('http://127.0.0.1:8000/api/summary/');\n      this.categorySales = res.data.data.category_sales;\n    } catch (error) {\n      this.errorMsg = '获取后端数据失败';\n      console.error(error);\n    } finally {\n      this.loading = false;\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","loading","errorMsg","categorySales","mounted","res","get","category_sales","error","console"],"sources":["src/views/TestApi.vue"],"sourcesContent":["<template>\r\n  <div style=\"padding: 20px;\">\r\n    <h1>后端接口测试页</h1>\r\n\r\n    <p v-if=\"loading\">数据加载中...</p>\r\n    <p v-else-if=\"errorMsg\" style=\"color: red;\">{{ errorMsg }}</p>\r\n\r\n    <div v-else>\r\n      <h2>分类销量数据</h2>\r\n      <ul>\r\n        <li v-for=\"item in categorySales\" :key=\"item.category\">\r\n          {{ item.category }} - {{ item.sales }}\r\n        </li>\r\n      </ul>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\n\r\nexport default {\r\n  name: 'TestApi',\r\n  data() {\r\n    return {\r\n      loading: true,\r\n      errorMsg: '',\r\n      categorySales: []\r\n    }\r\n  },\r\n  async mounted() {\r\n    try {\r\n      const res = await axios.get('http://127.0.0.1:8000/api/summary/')\r\n      this.categorySales = res.data.data.category_sales\r\n    } catch (error) {\r\n      this.errorMsg = '获取后端数据失败'\r\n      console.error(error)\r\n    } finally {\r\n      this.loading = false\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AAmBA,OAAAA,KAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,QAAA;MACAC,aAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA;MACA,MAAAC,GAAA,SAAAP,KAAA,CAAAQ,GAAA;MACA,KAAAH,aAAA,GAAAE,GAAA,CAAAL,IAAA,CAAAA,IAAA,CAAAO,cAAA;IACA,SAAAC,KAAA;MACA,KAAAN,QAAA;MACAO,OAAA,CAAAD,KAAA,CAAAA,KAAA;IACA;MACA,KAAAP,OAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}